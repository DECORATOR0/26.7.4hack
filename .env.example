INTERN_S2_API_BASE=https://chat.intern-ai.org.cn/api/v1
INTERN_S2_API_KEY=your_api_token_here
INTERN_S2_MODEL=intern-s2-preview

# Minimal SoccerMate V4.5 runtime settings.
# Put the full match video at this path, or change this value to an absolute path.
SOCCERMATE_VIDEO_PATH=./德国_库拉索.mp4
SOCCERMATE_MATCH_INFO_PATH=./examples/match_info.germany_curacao.json

# Keep true for demos/re-runs. Set false, or delete output folders, to force all stages from video again.
SOCCERMATE_REUSE_COMPLETED_STAGE_OUTPUTS=true
SOCCERMATE_RESUME_CACHED_MODEL_CALLS=true

# Web data is generated by default. Clips/montage need a large source video under web_demo/assets/source_match.mp4.
SOCCERMATE_BUILD_WEB_DATA=true
SOCCERMATE_WEB_SKIP_CLIPS=true
SOCCERMATE_WEB_SKIP_MONTAGE=true

# Stable V4.5 concurrency/rate settings.
SOCCERMATE_FRAME_INTERVAL_SECONDS=2
SOCCERMATE_FRAME_SEGMENT_SECONDS=60
SOCCERMATE_FRAME_NARRATION_CONCURRENCY=8
SOCCERMATE_FRAME_NARRATION_RPM_LIMIT=15
SOCCERMATE_EVENT_AGENT_CONCURRENCY=3
SOCCERMATE_EVENT_AGENT_RPM_LIMIT=12
SOCCERMATE_SCOREBOARD_RPM_LIMIT=12
